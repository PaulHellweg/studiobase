{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./src/*"],
      "@studiobase/server/*": ["../server/src/*"]
    }
  },
  "include": ["src/**/*", "../server/src/trpc/**/*", "../server/src/types/**/*", "../server/src/services/**/*", "../server/src/middleware/encryption.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/__tests__/**/*"]
}
