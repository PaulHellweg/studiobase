{
  "name": "@studiobase/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:rich": "tsx src/db/seed-rich.ts"
  },
  "dependencies": {
    "@react-email/components": "^0.0.25",
    "@studiobase/shared": "workspace:*",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.0.0",
    "cors": "^2.8.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.41.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.0",
    "postgres": "^3.4.0",
    "stripe": "^17.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.0",
    "@types/nodemailer": "^6.4.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
