# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/studiobase

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=studiobase
KEYCLOAK_CLIENT_ID=studiobase-server
KEYCLOAK_CLIENT_SECRET=your-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@studiobase.local

# Security — PII encryption key (AES-256)
# Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32
